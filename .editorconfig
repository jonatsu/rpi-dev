# EditorConfig configuration - https://editorconfig.org/
# https://github.com/editorconfig/editorconfig/wiki

# This is the top-most .editorconfig file (do not search in parent directories)
root = true

### All files
[*]
indent_style = space
indent_size = 4
tab_width = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.toml]
indent_style = space
indent_size = 2

[*.sh]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{bb,bbappend,bbclass}]
indent_style = space
indent_size = 4

[*.{inc,conf}]
indent_style = space
indent_size = 4
